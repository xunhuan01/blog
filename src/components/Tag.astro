---
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "@/config";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
---

<li>
  <a
    href={getRelativeLocaleUrl(locale, `tags/${tag}/`)}
    transition:name={tag}
    class="block text-base sm:text-lg font-medium text-foreground/70 hover:text-accent transition-colors py-0.5"
  >
    #{tagName}
  </a>
</li>
