---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
// 置顶文章排前面，其余按时间
const pinned = sortedPosts.filter(p => p.data.featured);
const rest = sortedPosts.filter(p => !p.data.featured);
const displayPosts = [...pinned, ...rest];
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section class="pt-6 pb-6">
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {displayPosts.slice(0, postsConfig.perIndex).map(data => (
          <Card variant="h3" {...data} />
        ))}
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
