<script>
  function initSPA() {
    const isHome = window.location.pathname === "/" || window.location.pathname === "/index.html";
    document.querySelectorAll("nav.sm\\:hidden a[href='/'], nav.sm\\:hidden a[href='/tags/'], nav.sm\\:hidden a[href='/about/']").forEach(link => {
      link.addEventListener("click", e => {
        if (!isHome) return;
        e.preventDefault();
        const href = link.getAttribute("href");
        const panelId = href === "/" ? "home-panel" : href === "/tags/" ? "tags-panel" : "about-panel";
        document.querySelectorAll("#home-panel, #tags-panel, #about-panel").forEach(el => {
          el.style.display = el.id === panelId ? "block" : "none";
        });
      });
    });
  }
  initSPA();
  document.addEventListener("astro:page-load", initSPA);
</script>